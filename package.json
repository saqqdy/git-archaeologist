{
	"name": "git-archaeologist",
	"description": "AI-powered git blame enhancer — understand WHY code was written, not just WHO wrote it. Semantic code archaeology via Claude Code Skill",
	"version": "0.1.0",
	"packageManager": "pnpm@9.15.9",
	"bin": {
		"git-archaeologist": "./dist/cli.js"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"require": "./dist/index.js",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist",
		".claude",
		".claude-plugin"
	],
	"scripts": {
		"build": "run-s clean build:bundle build:types",
		"build:bundle": "tsup",
		"build:types": "tsc --emitDeclarationOnly",
		"clean": "rm-all dist",
		"dev": "tsup --watch",
		"lint": "eslint --fix .",
		"prettier": "prettier --write \"**/*.{js,ts,mjs,yml,json,md}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"dist": "run-s lint build",
		"typecheck": "tsc --noEmit",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"devDependencies": {
		"@eslint-sets/eslint-config": "^6.3.1",
		"@types/node": "^26.0.0",
		"eslint": "^9.39.4",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.4",
		"prettier-config-common": "^1.5.0",
		"rm-all": "^1.1.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitepress": "^1.6.4",
		"vitest": "^3.2.6"
	},
	"engines": {
		"node": ">=18.20"
	},
	"sideEffects": false,
	"keywords": [
		"git-archaeologist",
		"git-blame",
		"code-archaeology",
		"code-history",
		"decision-archaeology",
		"claude-code",
		"claude-code-skill"
	],
	"license": "MIT",
	"author": "saqqdy<https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/git-archaeologist#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/git-archaeologist/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/git-archaeologist.git"
	}
}
